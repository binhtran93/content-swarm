# Firebase Web SDK values used by the browser for email/password sign-in.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Admin values used only on the server.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_OWNER_UID=

# Optional AI. Manual authoring does not require either provider.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional paid keyword discovery. Manual backlog features do not require these.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Optional local emulator endpoints, for example 127.0.0.1:9099.
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=
FIREBASE_AUTH_EMULATOR_HOST=
FIRESTORE_EMULATOR_HOST=
