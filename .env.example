# Firebase Web SDK values used by the browser for email/password sign-in.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Admin values used only on the server.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_OWNER_UID=

# Optional AI. Manual authoring does not require either provider.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional paid keyword discovery. Manual backlog features do not require these.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Optional local emulator endpoints, for example 127.0.0.1:9099.
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=
FIREBASE_AUTH_EMULATOR_HOST=
FIRESTORE_EMULATOR_HOST=

# Public deployment routing. Main deployments use project mode for /{projectId}
# paths. A dedicated deployment sets its PUBLIC_PROJECT_ID and uses root mode.
# Main deployments can return 404 for Projects hosted on dedicated domains by
# listing their IDs in PUBLIC_DISABLED_PROJECTS, separated by commas.
PUBLIC_PROJECT_ID=
PUBLIC_ROUTE_MODE=project
PUBLIC_DISABLED_PROJECTS=

# Public waitlist. Use Cloudflare's test keys locally and hostname-restricted
# production keys for deployed sites. The HMAC secret must be at least 32 chars.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
WAITLIST_EMAIL_HASH_SECRET=
