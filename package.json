{
  "name": "anmisoft-content-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:firebase": "firebase emulators:exec --project anmisoft-platform-test --only firestore \"vitest run --config vitest.firebase.config.ts\"",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run check:boundaries && npm run test && npm run test:firebase && npm run build"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.18",
    "@mdx-js/mdx": "^3.1.1",
    "ai": "^7.0.31",
    "firebase": "12.16.0",
    "firebase-admin": "14.1.0",
    "next": "16.2.10",
    "next-mdx-remote": "^6.0.0",
    "nextra": "^4.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "daisyui": "5.0.35",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "firebase-tools": "15.23.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
