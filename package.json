{
  "name": "anmisoft-content-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "start": "node scripts/start-standalone.mjs",
    "tools:setup": "node scripts/setup-media-tools.mjs",
    "tools:smoke": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/storyboard-splitter-smoke.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:firebase": "firebase emulators:exec --project anmisoft-platform-test --only firestore \"vitest run --config vitest.firebase.config.ts\"",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run check:boundaries && npm run test && npm run test:firebase && npm run build"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.18",
    "@mdx-js/mdx": "^3.1.1",
    "@mdxeditor/editor": "^4.0.4",
    "@next/third-parties": "16.2.10",
    "ai": "^7.0.31",
    "archiver": "8.0.0",
    "country-flag-icons": "^1.6.20",
    "firebase": "12.16.0",
    "firebase-admin": "14.1.0",
    "github-slugger": "^2.0.0",
    "google-auth-library": "^10.9.0",
    "lucide-react": "^1.25.0",
    "mdast-util-to-string": "^4.0.0",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "next-mdx-remote": "^6.0.0",
    "nextjs-toploader": "^3.9.17",
    "nextra": "^4.6.1",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "server-only": "0.0.1",
    "sharp": "0.35.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/archiver": "8.0.0",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "daisyui": "5.0.35",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "firebase-tools": "15.23.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
